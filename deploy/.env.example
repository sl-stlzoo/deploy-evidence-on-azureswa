# =============================================================================
# Evidence.dev → Azure Static Web Apps Deployment Configuration
# =============================================================================
# Copy this file to .env and populate all required values before running
# deploy.ps1. The .env file is gitignored and must never be committed.
#
# To rotate secrets or migrate to Azure Key Vault, see README.md § Key Vault.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure Subscription & Identity
# -----------------------------------------------------------------------------
# Your Azure Subscription ID (az account show --query id -o tsv)
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Your Entra (AAD) Tenant ID — the SINGLE tenant users must belong to
# (az account show --query tenantId -o tsv)
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Azure region for all resources. Choose one close to your users.
# Options: eastus, eastus2, westus2, westeurope, australiaeast, etc.
AZURE_LOCATION=eastus2

# -----------------------------------------------------------------------------
# Resource Group
# -----------------------------------------------------------------------------
# Name for the Azure resource group that will contain the SWA resource.
# Convention: rg-<workload>-<env>
AZURE_RESOURCE_GROUP=rg-evidence-prod

# Optional: tags applied to the resource group (comma-separated key=value)
# AZURE_RESOURCE_TAGS=environment=production,workload=evidence,owner=data-team

# -----------------------------------------------------------------------------
# Azure Static Web App
# -----------------------------------------------------------------------------
# Globally unique name for the SWA resource.
# Convention: swa-<workload>-<env>
SWA_NAME=swa-evidence-prod

# Pricing tier. Must be "Standard" for custom auth (Entra ID).
# Free tier does NOT support custom authentication providers.
SWA_SKU=Standard

# Filled automatically by provisioning script — do not edit manually.
# This is the SWA deployment token used by the SWA CLI and GitHub Actions.
SWA_DEPLOYMENT_TOKEN=

# Filled automatically — the *.azurestaticapps.net default hostname.
SWA_DEFAULT_HOSTNAME=

# -----------------------------------------------------------------------------
# Entra ID App Registration (filled by 02-register-app.ps1)
# -----------------------------------------------------------------------------
# Display name for the Entra app registration.
AAD_APP_NAME=evidence-swa-prod

# Filled automatically after app registration is created.
AAD_CLIENT_ID=

# Filled automatically — store securely, never commit.
AAD_CLIENT_SECRET=

# Optional: comma-separated UPNs (emails) that receive the evidence_admin role
# in addition to evidence_user. Leave blank to grant only evidence_user to all
# verified tenant members.
# EVIDENCE_ADMIN_USERS=alice@example.com,bob@example.com

# Optional: restrict to a specific Entra security group (Object ID).
# When set, only members of this group receive the evidence_user role.
# Leave blank to grant evidence_user to ALL authenticated tenant members.
# EVIDENCE_ALLOWED_GROUP_ID=

# -----------------------------------------------------------------------------
# GitHub Repository (for CI/CD via GitHub Actions)
# -----------------------------------------------------------------------------
# Full HTTPS URL of the private GitHub repository containing this project.
GITHUB_REPO_URL=https://github.com/your-org/your-evidence-project

# Branch to deploy from.
GITHUB_BRANCH=main

# Optional: GitHub Personal Access Token with repo + workflow scopes.
# Required only if you want the script to automatically register the
# SWA deployment token as a GitHub Actions secret via the gh CLI.
# Leave blank to configure GitHub Actions manually (see README).
# GITHUB_PAT=ghp_...

# -----------------------------------------------------------------------------
# Evidence.dev Build
# -----------------------------------------------------------------------------
# Node.js version to use. Evidence.dev requires Node 18+.
NODE_VERSION=20

# Relative path from deploy/ to the Evidence.dev project root.
# Default ".." means deploy/ is a direct subdirectory of the project root.
EVIDENCE_PROJECT_ROOT=..

# -----------------------------------------------------------------------------
# Custom Domain (out of scope for initial deployment — see README § Custom Domain)
# -----------------------------------------------------------------------------
# Primary domain you own (e.g. example.com). The SWA will be bound as a subdomain.
# CUSTOM_DOMAIN_APEX=example.com

# Subdomain prefix for the Evidence instance (e.g. "analytics" → analytics.example.com)
# CUSTOM_DOMAIN_SUBDOMAIN=analytics

# Fully-qualified custom domain — computed from above, or set explicitly.
# CUSTOM_DOMAIN=analytics.example.com

# DNS provider (informational only — used in README guidance).
# CUSTOM_DOMAIN_DNS_PROVIDER=cloudflare
